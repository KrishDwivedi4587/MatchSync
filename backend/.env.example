# ---------------------------------------------------------------------------
# MatchSync backend environment (example).
# Copy to `.env` and adjust. NEVER commit a real `.env`.
# In production these are injected by the platform/secrets manager, not a file.
# ---------------------------------------------------------------------------

# --- Application ---
APP_NAME=MatchSync
ENVIRONMENT=local            # local | development | staging | production
DEBUG=true
API_V1_PREFIX=/api/v1

# --- Logging ---
LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_FORMAT=console           # console (dev) | json (prod)

# --- Database (PostgreSQL) ---
POSTGRES_HOST=localhost      # use "postgres" when running via docker-compose
POSTGRES_PORT=5432
POSTGRES_USER=matchsync
POSTGRES_PASSWORD=matchsync
POSTGRES_DB=matchsync

# --- Redis / Celery ---
REDIS_HOST=localhost         # use "redis" when running via docker-compose
REDIS_PORT=6379
REDIS_DB=0

# --- Security / CORS ---
CORS_ORIGINS=["http://localhost:3000"]
SECRET_KEY=change-me-in-production   # signs JWTs + derives token encryption key

# --- Google OAuth ---
GOOGLE_CLIENT_ID=                    # from Google Cloud Console (OAuth client)
GOOGLE_CLIENT_SECRET=
# Must EXACTLY match an Authorized redirect URI in the Google console.
# Dev uses the frontend proxy path so cookies stay first-party (Next.js rewrite).
GOOGLE_REDIRECT_URI=http://localhost:3000/api/v1/auth/callback

# --- Sports providers (Stage 6) ---
# A provider with a blank key is registered but reports `configured: false`
# and refuses network calls. Keys are secrets — never commit real values.
FOOTBALL_API_BASE_URL=https://api.football-data.org/v4
FOOTBALL_API_KEY=
VALORANT_API_BASE_URL=https://vlrggapi.vercel.app
VALORANT_API_KEY=
BASKETBALL_API_BASE_URL=https://api.balldontlie.io/v1
BASKETBALL_API_KEY=
SPORTS_CACHE_TTL_SECONDS=3600

# --- Fixture ingestion (Stage 7) ---
FIXTURE_IMPORT_PAST_DAYS=7
FIXTURE_IMPORT_FUTURE_DAYS=120
FIXTURE_IMPORT_BATCH_SIZE=500
FIXTURE_MATCH_TOLERANCE_HOURS=12

# --- Synchronization engine (Stage 8) ---
SYNC_WINDOW_PAST_DAYS=1
SYNC_WINDOW_FUTURE_DAYS=90
SYNC_BATCH_SIZE=50
SYNC_MAX_FIXTURES=5000
SYNC_MAX_ACTIONS=2000
SYNC_DEFAULT_EVENT_DURATION_MINUTES=120
SYNC_MAX_ITEM_RETRIES=3
SYNC_RETRY_WINDOW_DAYS=7
SYNC_CONFLICT_POLICY=fixture_wins   # fixture_wins | user_wins
SYNC_CANCELLED_POLICY=annotate      # annotate | delete
SYNC_SKIP_EMPTY_RUNS=true

# --- Orchestration platform (Stage 9) ---
SCHEDULER_SCAN_INTERVAL_MINUTES=5
SCHEDULER_SCAN_BATCH_SIZE=500
LOCK_TTL_SECONDS=120
JOB_MAX_ATTEMPTS=5
JOB_RETRY_BASE_DELAY_SECONDS=30
JOB_RETRY_MAX_DELAY_SECONDS=3600
JOB_RATE_LIMIT_FLOOR_SECONDS=60
JOB_RETENTION_SECONDS=604800
STUCK_JOB_THRESHOLD_SECONDS=1800
HEARTBEAT_TTL_SECONDS=60
WORKER_SOFT_TIME_LIMIT_SECONDS=600
WORKER_TIME_LIMIT_SECONDS=660
WORKER_PREFETCH_MULTIPLIER=1
WORKER_MAX_TASKS_PER_CHILD=200
SYNC_TASK_RATE_LIMIT=120/m

# --- Auth: JWT + cookies + redirects ---
FRONTEND_URL=http://localhost:3000
POST_LOGIN_PATH=/dashboard
POST_LOGOUT_PATH=/login
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30
# COOKIE_SECURE unset -> auto (off for local, on otherwise). Force with true/false.
# COOKIE_SECURE=false
COOKIE_SAMESITE=lax
# COOKIE_DOMAIN=                     # leave empty for host-only cookies
