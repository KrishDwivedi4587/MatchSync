# ---------------------------------------------------------------------------
# MatchSync frontend environment (example). Copy to `.env.local`.
# Only NEXT_PUBLIC_* variables are exposed to the browser — never put secrets
# here. Server-only variables (no prefix) are used by the Next.js server/proxy.
# ---------------------------------------------------------------------------

# Same-origin API path. Requests go through the Next.js /api proxy (rewrites)
# so auth cookies stay first-party. Usually leave as-is.
NEXT_PUBLIC_API_BASE_URL=/api/v1

# Backend origin the proxy forwards to (server-side only). Use the docker
# service name when running via compose (http://api:8000).
BACKEND_URL=http://localhost:8000
